{
  "name": "moneymate-api",
  "version": "1.0.0",
  "description": "MoneyMate Expense Tracker backend API",
  "homepage": "https://github.com/MoneyMate-ABP/moneymate-api#readme",
  "bugs": {
    "url": "https://github.com/MoneyMate-ABP/moneymate-api/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MoneyMate-ABP/moneymate-api.git"
  },
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "migrate": "knex --knexfile knexfile.js migrate:latest",
    "migrate:rollback": "knex --knexfile knexfile.js migrate:rollback",
    "migrate:fresh": "knex --knexfile knexfile.js migrate:rollback --all && npm run migrate && npm run seed",
    "migrate:make": "knex --knexfile knexfile.js migrate:make",
    "seed": "knex --knexfile knexfile.js seed:run",
    "seed:make": "knex --knexfile knexfile.js seed:make",
    "test": "node --test"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.2.8",
    "morgan": "^1.10.1",
    "mysql2": "^3.20.0",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
